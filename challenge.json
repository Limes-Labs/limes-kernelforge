{
  "id": "limes-kernelforge",
  "name": "Limes KernelForge",
  "cli": "limes-kernelforge",
  "version": "0.1.0",
  "score": {
    "direction": "minimize",
    "primaryMetric": "hidden_geomean_runtime_ms",
    "publicMetric": "public_geomean_runtime_ms",
    "officialMetric": "hidden_geomean_runtime_ms",
    "officialHiddenMetric": "hidden_geomean_runtime_ms"
  },
  "editablePaths": [
    "solution/rmsnorm.py",
    "solution/rope.py",
    "solution/attention.py",
    "solution/kv_decode.py",
    "solution/native/README.md"
  ],
  "forbiddenPaths": [
    "harness/**",
    "baselines/**",
    "cases/**",
    "verifier/**",
    "hidden_cases/**",
    "challenge.json",
    "score.json",
    "leaderboard/**"
  ],
  "commands": {
    "test": "python3 -m unittest discover -s tests",
    "score": "python3 harness/score.py --output score.json",
    "probe": "python3 scripts/run_invariant_probes.py",
    "publicAudit": "python3 scripts/run_public_audit.py",
    "checkPublicBaseline": "python3 scripts/check_public_baseline.py --input baselines/public-smoke-baseline.json",
    "buildSubmissionBundle": "python3 scripts/build_submission_bundle.py --output submission-bundle.json --base origin/main",
    "validateSubmissionBundle": "python3 scripts/validate_submission_bundle.py --input submission-bundle.json",
    "buildCandidatePacket": "python3 scripts/build_candidate_packet.py --manifest submission.json --source-bundle submission-bundle.json --search-ledger search-ledger.json --agent-notes agent-notes.json --public-score score.json --invariant-probes invariant-probes.json --public-audit public-audit.json --output candidate-packet.json",
    "validateCandidatePacket": "python3 scripts/validate_candidate_packet.py --input candidate-packet.json",
    "verify": "python3 harness/verify_hidden.py --public-contract-only",
    "audit": "python3 scripts/check_submission.py --manifest submission.json --base origin/main",
    "validateLocalBundle": "python3 scripts/validate_local_bundle.py --manifest submission.json --base origin/main",
    "validateLeaderboard": "python3 scripts/validate_leaderboard.py --input examples/limeslabs/leaderboard.example.json",
    "validateAgentNotes": "python3 scripts/validate_agent_notes.py --input templates/agent-notes.example.json",
    "validateSearchLedger": "python3 scripts/validate_search_ledger.py --input templates/search-ledger.example.json",
    "validateReplayResult": "python3 scripts/validate_replay_result.py --input templates/replay-result.example.json",
    "validateRunnerManifest": "python3 scripts/validate_runner_manifest.py --input verifier/trusted-runner-manifest.example.json",
    "validateBaselineRecord": "python3 scripts/validate_baseline_record.py --input verifier/baseline-record.example.json",
    "validatePromotionPacket": "python3 scripts/validate_promotion_packet.py --input templates/promotion-packet.example.json"
  },
  "statusModel": [
    "local",
    "candidate",
    "verified",
    "promoted",
    "replicated",
    "scaled"
  ]
}
